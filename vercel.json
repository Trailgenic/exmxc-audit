{
  "version": 2,
  "routes": [
    { "src": "^/api/audit$", "dest": "/api/audit.js" },
    { "src": "^/api/batch-run$", "dest": "/api/batch-run.js" },

    { "src": "^/batch$", "dest": "/public/batch-run.html" },
    { "src": "^/batch-run$", "dest": "/public/batch-run.html" },
    { "src": "^/style.css$", "dest": "/public/style.css" },

    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
