{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/api/audit$", "dest": "/api/audit.js" },
    { "src": "^/api/scan$", "dest": "/api/scan.js" },
    { "src": "^/api/predictive-audit$", "dest": "/api/predictive-audit.js" },

    { "src": "^/api/audit-v5$", "dest": "/api/audit.js" },
    { "src": "^/api/batch-v5$", "dest": "/api/batch-run.js" },

    { "src": "^/batch$", "dest": "/public/batch.html" },
    { "src": "^/predictive$", "dest": "/public/predictive.html" },
    { "src": "^/style.css$", "dest": "/public/styles.css" },

    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
