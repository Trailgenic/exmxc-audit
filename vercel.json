{
  "version": 2,
  "routes": [
    { "src": "^/api/audit$", "dest": "/api/audit.js" },
    { "src": "^/api/batch$", "dest": "/api/batch-run.js" },

    { "src": "^/batch$", "dest": "/public/batch.html" },
    { "src": "^/predictive$", "dest": "/public/predictive.html" },
    { "src": "^/style.css$", "dest": "/public/style.css" },

    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
